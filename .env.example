# Google OAuth Client ID (Google Cloud Console)
# https://console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
# Application type: Web application
# Authorized JS origins: http://localhost:54321 (dev), https://taxtoo.app (prod)
# Enable the Google Drive API.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Microsoft (Entra ID) Application (client) ID for the SPA app registration.
# Redirect URIs: http://localhost:54321, https://taxtoo.app
# API permissions: User.Read, Files.ReadWrite
VITE_MICROSOFT_CLIENT_ID=your-microsoft-client-id
